# Copy to .env.local and fill in values. Never commit .env.local.

# Postgres connection string (local docker: yarn db:up)
DATABASE_URL=postgresql://postgres:password@localhost:5432/chronos

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# On Vercel, auth base URL is auto-detected from VERCEL_URL — set BETTER_AUTH_URL
# to your custom domain when you add one. Optional extra origins for preview deploys:
# BETTER_AUTH_TRUSTED_ORIGINS=https://day-mirror-git-main-you.vercel.app

# Optional: Google OAuth (add when ready)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Development only (ignored in production) ---
DEV_USER_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# Optional: extra allowed CORS origins for the Hono API (comma-separated)
# ALLOWED_ORIGINS=https://staging.example.com
